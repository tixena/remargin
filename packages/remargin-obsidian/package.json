{
  "name": "remargin-obsidian",
  "version": "0.1.0",
  "private": true,
  "description": "Remargin plugin for Obsidian",
  "main": "main.js",
  "scripts": {
    "generate-types": "cd ../.. && cargo run --bin generate_types && cd packages/remargin-obsidian && pnpm exec biome check --write src/generated/",
    "predev": "pnpm run generate-types",
    "dev": "node esbuild.config.mjs",
    "prebuild": "pnpm run generate-types",
    "build": "node esbuild.config.mjs production",
    "lint": "pnpm exec biome check --write --diagnostic-level=error",
    "test": "node --experimental-strip-types --no-warnings --test 'src/**/*.test.ts'",
    "typecheck": "pnpm exec tsc --noEmit"
  },
  "dependencies": {
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.8.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^2.6.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@codemirror/state": "^6.4.1",
    "@codemirror/view": "^6.26.0",
    "@types/node": "^20.11.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "autoprefixer": "^10.4.20",
    "esbuild": "^0.25.0",
    "esbuild-postcss": "^0.0.4",
    "obsidian": "^1.8.7",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3"
  }
}
