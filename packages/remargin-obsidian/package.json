{
  "name": "remargin-obsidian",
  "version": "0.1.8",
  "private": true,
  "type": "module",
  "description": "Remargin plugin for Obsidian",
  "main": "main.js",
  "scripts": {
    "generate-types": "cd ../.. && cargo xtask generate-types && cd packages/remargin-obsidian && pnpm exec biome check --write src/generated/",
    "predev": "pnpm run generate-types",
    "dev": "node esbuild.config.mjs",
    "prebuild": "pnpm run generate-types",
    "build": "node esbuild.config.mjs production",
    "lint": "pnpm exec biome check --write --diagnostic-level=error",
    "test": "node --loader=./test-loader.mjs --experimental-strip-types --no-warnings --test 'src/**/*.test.ts'",
    "typecheck": "pnpm exec tsgo --noEmit"
  },
  "dependencies": {
    "@radix-ui/react-checkbox": "1.3.3",
    "@radix-ui/react-collapsible": "1.1.12",
    "@radix-ui/react-dropdown-menu": "2.1.16",
    "@radix-ui/react-scroll-area": "1.2.10",
    "@radix-ui/react-select": "2.2.6",
    "@radix-ui/react-separator": "1.1.8",
    "@radix-ui/react-slot": "1.2.4",
    "@radix-ui/react-toggle": "1.1.10",
    "@radix-ui/react-toggle-group": "1.1.11",
    "@radix-ui/react-tooltip": "1.2.8",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "diacritic-regex": "1.2.0",
    "lucide-react": "1.8.0",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "tailwind-merge": "3.5.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@codemirror/lang-markdown": "6.5.0",
    "@codemirror/language": "6.12.3",
    "@codemirror/state": "6.5.0",
    "@codemirror/view": "6.38.6",
    "@lezer/highlight": "1.2.3",
    "@tailwindcss/postcss": "4.2.2",
    "@types/node": "25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@typescript/native-preview": "latest",
    "autoprefixer": "10.4.27",
    "esbuild": "0.28.0",
    "esbuild-postcss": "0.0.4",
    "obsidian": "1.12.3",
    "postcss": "8.5.9",
    "tailwindcss": "4.2.2"
  }
}
