---
import { asset } from '../lib/url';
import '../styles/global.css';

import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import Footer from '../components/Footer.astro';

import Problem from '../components/sections/Problem.astro';
import Protocol from '../components/sections/Protocol.astro';
import Anatomy from '../components/sections/Anatomy.astro';
import MultiAgent from '../components/sections/MultiAgent.astro';
import Preservation from '../components/sections/Preservation.astro';
import Permissions from '../components/sections/Permissions.astro';
import Install from '../components/sections/Install.astro';
import Roadmap from '../components/sections/Roadmap.astro';

const title = 'Remargin — a communication protocol for humans and agents';
const description = 'Remargin turns any markdown file into a multi-player surface where humans and AI agents leave threaded, addressable, signed, integrity-checked comments.';
const siteUrl = Astro.site ? new URL(import.meta.env.BASE_URL, Astro.site).toString() : '';
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />

  <link rel="icon" type="image/svg+xml" href={asset('favicon.svg')} />
  <link rel="alternate icon" type="image/png" href={asset('favicon.png')} />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Geist+Mono:wght@400;500;600;700&family=Inter:wght@400;500;600&display=swap" />

  <meta property="og:type" content="website" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  {siteUrl && <meta property="og:url" content={siteUrl} />}
  <meta property="og:image" content={asset('og.png')} />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={asset('og.png')} />
</head>
<body>
  <a class="skip" href="#main">Skip to content</a>
  <Nav />
  <main id="main">
    <Hero />
    <Problem />
    <Protocol />
    <Anatomy />
    <MultiAgent />
    <Preservation />
    <Permissions />
    <Install />
    <Roadmap />
  </main>
  <Footer />

  <!-- Copy-to-clipboard for <CodeBlock> components -->
  <script is:inline>
    (function () {
      var buttons = document.querySelectorAll('.codeblock__copy');
      buttons.forEach(function (btn) {
        btn.addEventListener('click', function () {
          var block = btn.closest('.codeblock');
          if (!block) return;
          var code = block.querySelector('pre code');
          if (!code) return;
          var text = code.innerText;
          if (!navigator.clipboard) return;
          navigator.clipboard.writeText(text).then(function () {
            var label = btn.querySelector('span');
            var prev = label ? label.textContent : 'copy';
            if (label) label.textContent = 'copied';
            btn.classList.add('is-copied');
            window.setTimeout(function () {
              if (label) label.textContent = prev;
              btn.classList.remove('is-copied');
            }, 1400);
          });
        });
      });
    })();
  </script>
</body>
</html>
