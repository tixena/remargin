---
/**
 * <Annotation num="1">…explanation HTML…</Annotation>
 *
 * Used as a numbered legend entry next to the centerpiece CommentBlock in §3.
 * On mobile the parent .anatomy grid collapses and these stack below the block.
 */
interface Props {
  num: number | string;
}
const { num } = Astro.props;
---
<div class="legend__item">
  <span class="legend__num">{num}</span>
  <div class="legend__text"><slot /></div>
</div>

<style is:global>
.legend {
  display: flex; flex-direction: column; gap: 14px;
  font-size: 13px;
  position: sticky; top: 88px;
}
.legend__item {
  display: grid; grid-template-columns: 24px 1fr; gap: 10px;
  align-items: start;
}
.legend__num {
  width: 22px; height: 22px;
  display: inline-flex; align-items: center; justify-content: center;
  border-radius: 50%;
  background: var(--color-brand-bg);
  color: var(--color-brand-soft);
  border: 1px solid rgba(127,109,242,0.35);
  font-family: var(--font-mono); font-size: 11px; font-weight: 600;
  font-variant-numeric: tabular-nums;
}
.legend__text { color: var(--color-text-muted); line-height: 1.5; }
.legend__text code {
  font-family: var(--font-mono); font-size: 12px;
  color: var(--color-text);
  background: var(--color-surface); padding: 1px 5px; border-radius: 3px;
  border: 1px solid var(--color-border-subtle);
}
</style>
